Algoritmo ejercico3
	Definir letra Como Caracter
	Escribir Sin Saltar "DIGITE UNA LETRTA: "
	Leer letra
	
	Segun letra Hacer
		"A" o "a":
			Escribir "EXELENTE"
		"B" o "b":
			Escribir "Bueno"
		"C" o "c":
			Escribir "Regular"
		"D" o "d":
			Escribir "Deficiente"
		"F" o "f":
			Escribir "REPROBADO"
			
		De Otro Modo:
			Escribir "digite una letrea bie"
	Fin Segun
	
FinAlgoritmo
